<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Брандмауэр" Height="720" Width="1080" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen" Background="#F4F4F5" FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
  <Window.Resources>
    <SolidColorBrush x:Key="TextPrimary" Color="#18181B"/>
    <SolidColorBrush x:Key="TextMuted" Color="#71717A"/>
    <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Border" Color="#E4E4E7"/>
    <SolidColorBrush x:Key="Accent" Color="#18181B"/>
    <SolidColorBrush x:Key="AccentHover" Color="#3F3F46"/>
    <SolidColorBrush x:Key="Allow" Color="#16A34A"/>
    <SolidColorBrush x:Key="Block" Color="#E11D48"/>
    <SolidColorBrush x:Key="FocusRing" Color="#2563EB"/>
    <SolidColorBrush x:Key="Canvas" Color="#F4F4F5"/>

    <Style x:Key="NavButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#F4F4F5"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource Accent}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="20,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#FAFAFA"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DangerGhostButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
      <Setter Property="Foreground" Value="{StaticResource Block}"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="#BE123C"/>
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Foreground" Value="#FDA4AF"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="StatCardButton" TargetType="Button">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#E4E4E7"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#FAFAFA"/>
                <Setter TargetName="bd" Property="BorderBrush" Value="#D4D4D8"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#F4F4F5"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ModernComboBox" TargetType="ComboBox">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="ModernTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FocusRing}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="SegmentButton" TargetType="ToggleButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="bd" Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#FAFAFA"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FilterSegmentButton" TargetType="ToggleButton" BasedOn="{StaticResource SegmentButton}">
      <Setter Property="Padding" Value="14,8"/>
    </Style>

    <Style x:Key="DirectionSegButton" TargetType="ToggleButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#FAFAFA"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SegInboundBtn" TargetType="ToggleButton" BasedOn="{StaticResource DirectionSegButton}">
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#EFF6FF"/>
          <Setter Property="Foreground" Value="#2563EB"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
        <Trigger Property="IsChecked" Value="False">
          <Setter Property="Foreground" Value="#71717A"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SegOutboundBtn" TargetType="ToggleButton" BasedOn="{StaticResource DirectionSegButton}">
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#FFF7ED"/>
          <Setter Property="Foreground" Value="#EA580C"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
        <Trigger Property="IsChecked" Value="False">
          <Setter Property="Foreground" Value="#71717A"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SegAllowBtn" TargetType="ToggleButton" BasedOn="{StaticResource SegmentButton}">
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#F0FDF4"/>
          <Setter Property="Foreground" Value="#16A34A"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SegBlockBtn" TargetType="ToggleButton" BasedOn="{StaticResource SegmentButton}">
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#FFF1F2"/>
          <Setter Property="Foreground" Value="#E11D48"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border x:Name="Track" Width="44" Height="24" CornerRadius="12" Background="#E4E4E7" Cursor="Hand">
              <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0">
                <Ellipse.Effect>
                  <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                </Ellipse.Effect>
              </Ellipse>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Track" Property="Background" Value="#18181B"/>
                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="White" BorderBrush="#E4E4E7" BorderThickness="0,0,1,0">
      <DockPanel Margin="20,28,20,24">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,32">
          <Border Width="40" Height="40" CornerRadius="10" Background="#18181B" Margin="0,0,0,14">
            <TextBlock Text="F" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Брандмауэр" FontSize="20" FontWeight="SemiBold" Foreground="#18181B"/>
          <TextBlock Text="Менеджер" FontSize="20" FontWeight="Light" Foreground="#71717A" Margin="0,-2,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom">
          <Border Background="#F4F4F5" CornerRadius="10" Padding="14">
            <StackPanel>
              <TextBlock Text="Сейчас в системе" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,8"/>
              <TextBlock x:Name="TxtStats" Text="0 правил" FontSize="12" Foreground="#71717A"/>
              <TextBlock x:Name="TxtStatsActive" Text="0 активных" FontSize="11" Foreground="#16A34A" Margin="0,4,0,0"/>
              <TextBlock x:Name="TxtStatsInactive" Text="0 отключённых" FontSize="11" Foreground="#71717A" Margin="0,2,0,0"/>
              <TextBlock Text="Группа: FirewallManager_Custom" FontSize="11" Foreground="#A1A1AA" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel>
          <Button x:Name="BtnNavRules" Style="{StaticResource NavButton}" Foreground="#18181B" FontWeight="SemiBold">
            <StackPanel Orientation="Horizontal">
              <Border Width="6" Height="6" CornerRadius="3" Background="#18181B" Margin="4,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="Правила" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button x:Name="BtnNavBackup" Style="{StaticResource NavButton}">
            <StackPanel Orientation="Horizontal">
              <Border Width="6" Height="6" CornerRadius="3" Background="#D4D4D8" Margin="4,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="Резервные копии" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Main content -->
    <Grid Grid.Column="1" Margin="36,28,36,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="0,0,0,16">
        <TextBlock x:Name="TxtPageTitle" Text="Правила" FontSize="26" FontWeight="SemiBold" Foreground="#18181B"/>
        <TextBlock x:Name="TxtRulesSummary" Text="Загрузка..." FontSize="13" Foreground="#71717A" Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Stats cards (click = quick filter) -->
      <Grid Grid.Row="1" Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Button x:Name="BtnStatTotal" Grid.Column="0" Style="{StaticResource StatCardButton}" Margin="0,0,8,0"
                ToolTip="Показать все правила">
          <StackPanel>
            <TextBlock x:Name="TxtStatTotal" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#18181B"/>
            <TextBlock Text="Всего правил" FontSize="11" Foreground="#71717A"/>
          </StackPanel>
        </Button>
        <Button x:Name="BtnStatActive" Grid.Column="1" Margin="0,0,8,0" Cursor="Hand" ToolTip="Фильтр: только активные">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource StatCardButton}">
              <Setter Property="Background" Value="#F0FDF4"/>
              <Setter Property="BorderBrush" Value="#BBF7D0"/>
            </Style>
          </Button.Style>
          <StackPanel>
            <TextBlock x:Name="TxtStatActive" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#16A34A"/>
            <TextBlock Text="Активные" FontSize="11" Foreground="#16A34A"/>
          </StackPanel>
        </Button>
        <Button x:Name="BtnStatInactive" Grid.Column="2" Margin="0,0,8,0" Cursor="Hand" ToolTip="Фильтр: только отключённые">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource StatCardButton}">
              <Setter Property="Background" Value="#F4F4F5"/>
            </Style>
          </Button.Style>
          <StackPanel>
            <TextBlock x:Name="TxtStatInactive" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#71717A"/>
            <TextBlock Text="Отключённые" FontSize="11" Foreground="#71717A"/>
          </StackPanel>
        </Button>
        <Button x:Name="BtnStatOutbound" Grid.Column="3" Cursor="Hand" ToolTip="Фильтр: только исходящие">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource StatCardButton}">
              <Setter Property="Background" Value="#FFF7ED"/>
              <Setter Property="BorderBrush" Value="#FED7AA"/>
            </Style>
          </Button.Style>
          <StackPanel>
            <TextBlock x:Name="TxtStatOutbound" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#EA580C"/>
            <TextBlock Text="Исходящие" FontSize="11" Foreground="#EA580C"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Toolbar + filters -->
      <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E4E4E7" BorderThickness="1"
              Padding="16" Margin="0,0,0,12">
        <StackPanel>
          <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtSearch" Style="{StaticResource ModernTextBox}" Grid.Column="0"
                     VerticalAlignment="Center" Margin="0,0,8,0"
                     ToolTip="Поиск по названию, порту, IP, протоколу (Ctrl+F)">
              <TextBox.Resources>
                <Style TargetType="Border">
                  <Setter Property="CornerRadius" Value="8"/>
                </Style>
              </TextBox.Resources>
            </TextBox>
            <Button x:Name="BtnRefresh" Grid.Column="1" Style="{StaticResource GhostButton}" Content="Обновить"
                    Margin="0,0,8,0" ToolTip="Обновить список (F5)"/>
            <Button x:Name="BtnAdd" Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="+ Новое правило"
                    ToolTip="Создать правило (Ctrl+N)"/>
          </Grid>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <TextBlock Text="Направление" FontSize="12" Foreground="#71717A" VerticalAlignment="Center"
                         Margin="0,0,10,0" Width="92"/>
              <Border Background="#F4F4F5" CornerRadius="8" Padding="4">
                <StackPanel Orientation="Horizontal">
                  <ToggleButton x:Name="SegFilterAll" Style="{StaticResource FilterSegmentButton}" Content="Все" IsChecked="True"/>
                  <ToggleButton x:Name="SegFilterInbound" Style="{StaticResource FilterSegmentButton}" Content="Входящие"/>
                  <ToggleButton x:Name="SegFilterOutbound" Style="{StaticResource FilterSegmentButton}" Content="Исходящие"/>
                </StackPanel>
              </Border>
            </StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Статус" FontSize="12" Foreground="#71717A" VerticalAlignment="Center"
                           Margin="0,0,10,0" Width="92"/>
                <Border Background="#F4F4F5" CornerRadius="8" Padding="4">
                  <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="SegStatusAll" Style="{StaticResource FilterSegmentButton}" Content="Все" IsChecked="True"/>
                    <ToggleButton x:Name="SegStatusActive" Style="{StaticResource FilterSegmentButton}" Content="Активные"/>
                    <ToggleButton x:Name="SegStatusInactive" Style="{StaticResource FilterSegmentButton}" Content="Отключённые"/>
                  </StackPanel>
                </Border>
              </StackPanel>
              <TextBlock x:Name="TxtFilterInfo" Grid.Column="1" Text="" FontSize="12" Foreground="#A1A1AA"
                         VerticalAlignment="Center" HorizontalAlignment="Right" Margin="12,0,0,0"/>
            </Grid>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Rules list -->
      <Border Grid.Row="3" Background="White" CornerRadius="12" BorderBrush="#E4E4E7" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E4E4E7" BorderThickness="0,0,0,1"
                  CornerRadius="12,12,0,0" Padding="28,10,28,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="104"/>
                <ColumnDefinition Width="116"/>
                <ColumnDefinition Width="72"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="1" Text="Правило" FontSize="11" FontWeight="SemiBold" Foreground="#A1A1AA"/>
              <TextBlock Grid.Column="2" Text="Направление" FontSize="11" FontWeight="SemiBold" Foreground="#A1A1AA" HorizontalAlignment="Center"/>
              <TextBlock Grid.Column="3" Text="Действие" FontSize="11" FontWeight="SemiBold" Foreground="#A1A1AA" HorizontalAlignment="Center"/>
              <TextBlock Grid.Column="4" Text="Статус" FontSize="11" FontWeight="SemiBold" Foreground="#A1A1AA" HorizontalAlignment="Center"/>
            </Grid>
          </Border>
          <ListBox x:Name="RulesList" Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="4"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="8,4"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Border x:Name="Bd" Background="Transparent" CornerRadius="10" Padding="16,14"
                              BorderBrush="Transparent" BorderThickness="1">
                        <ContentPresenter/>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                          <Setter TargetName="Bd" Property="Background" Value="#F4F4F5"/>
                          <Setter TargetName="Bd" Property="BorderBrush" Value="#E4E4E7"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Bd" Property="Background" Value="#FAFAFA"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Enabled}" Value="False">
                          <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                        </DataTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="104"/>
                    <ColumnDefinition Width="116"/>
                    <ColumnDefinition Width="72"/>
                  </Grid.ColumnDefinitions>
                  <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,14,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                      <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#16A34A"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Action}" Value="Block">
                            <Setter Property="Fill" Value="#E11D48"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Ellipse.Style>
                  </Ellipse>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium" Foreground="#18181B"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                      <TextBlock Text="{Binding Protocol}" FontSize="12" Foreground="#71717A"/>
                      <TextBlock Text=" &#x00B7; " FontSize="12" Foreground="#D4D4D8"/>
                      <TextBlock Text="{Binding Ports}" FontSize="12" Foreground="#71717A"/>
                      <TextBlock Text=" &#x00B7; " FontSize="12" Foreground="#D4D4D8"/>
                      <TextBlock Text="{Binding RemoteIp}" FontSize="12" Foreground="#71717A"/>
                    </StackPanel>
                  </StackPanel>
                  <Border Grid.Column="2" CornerRadius="6" Padding="10,4" Margin="0,0,4,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="#EFF6FF"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Direction}" Value="Outbound">
                            <Setter Property="Background" Value="#FFF7ED"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock FontSize="11" FontWeight="SemiBold">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="Входящие"/>
                          <Setter Property="Foreground" Value="#2563EB"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Direction}" Value="Outbound">
                              <Setter Property="Text" Value="Исходящие"/>
                              <Setter Property="Foreground" Value="#EA580C"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Border>
                  <Border Grid.Column="3" CornerRadius="6" Padding="10,4" Margin="0,0,4,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="#F0FDF4"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Action}" Value="Block">
                            <Setter Property="Background" Value="#FFF1F2"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ActionRu}" FontSize="11" FontWeight="SemiBold">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="#16A34A"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Action}" Value="Block">
                              <Setter Property="Foreground" Value="#E11D48"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Border>
                  <Border Grid.Column="4" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="#F4F4F5"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Enabled}" Value="True">
                            <Setter Property="Background" Value="#ECFDF5"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding EnabledRu}" FontSize="11" FontWeight="SemiBold">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="#71717A"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Enabled}" Value="True">
                              <Setter Property="Foreground" Value="#16A34A"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
            <Border Width="48" Height="48" CornerRadius="24" Background="#F4F4F5" HorizontalAlignment="Center" Margin="0,0,0,12">
              <TextBlock Text="—" FontFamily="Segoe UI" FontSize="28" Foreground="#D4D4D8"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="TxtEmptyTitle" Text="Правил пока нет" FontSize="16" FontWeight="Medium"
                       Foreground="#71717A" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtEmptySubtitle" Text="Создайте первое правило для управления трафиком"
                       FontSize="13" Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,6,0,0" TextAlignment="Center"/>
            <Button x:Name="BtnEmptyAdd" Style="{StaticResource PrimaryButton}" Content="+ Создать правило"
                    Margin="0,16,0,0" HorizontalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Action bar -->
      <Grid Grid.Row="4" Margin="0,16,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <Button x:Name="BtnEnable" Style="{StaticResource GhostButton}" Content="Включить" Margin="0,0,8,0"
                  ToolTip="Включить выбранное правило" IsEnabled="False"/>
          <Button x:Name="BtnDisable" Style="{StaticResource GhostButton}" Content="Отключить" Margin="0,0,8,0"
                  ToolTip="Отключить выбранное правило" IsEnabled="False"/>
          <Button x:Name="BtnDelete" Style="{StaticResource DangerGhostButton}" Content="Удалить"
                  ToolTip="Удалить выбранное правило (Delete)" IsEnabled="False"/>
        </StackPanel>
        <TextBlock x:Name="TxtSelectionInfo" Grid.Column="1" Text="Выберите правило в списке"
                   FontSize="12" Foreground="#A1A1AA" VerticalAlignment="Center" Margin="16,0"
                   TextTrimming="CharacterEllipsis"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal">
          <Button x:Name="BtnExport" Style="{StaticResource GhostButton}" Content="Экспорт" Margin="0,0,8,0"
                  ToolTip="Сохранить правила в JSON"/>
          <Button x:Name="BtnImport" Style="{StaticResource GhostButton}" Content="Импорт"
                  ToolTip="Загрузить правила из JSON"/>
        </StackPanel>
      </Grid>
    </Grid>

    <!-- Add Rule Modal -->
    <Grid x:Name="ModalOverlay" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed">
      <Border Background="White" CornerRadius="16" MaxWidth="520" VerticalAlignment="Center"
              HorizontalAlignment="Center" Margin="40" Padding="32">
        <Border.Effect>
          <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
          <StackPanel>
            <TextBlock Text="Новое правило" FontSize="22" FontWeight="SemiBold" Foreground="#18181B" Margin="0,0,0,4"/>
            <TextBlock Text="Настройте параметры брандмауэра" FontSize="13" Foreground="#71717A" Margin="0,0,0,24"/>

            <TextBlock Text="Направление трафика" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="#F4F4F5" CornerRadius="10" Padding="4">
                <ToggleButton x:Name="SegInbound" Style="{StaticResource SegInboundBtn}" IsChecked="True" HorizontalAlignment="Stretch">
                  <StackPanel>
                    <TextBlock Text="Входящие" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="трафик к ПК" FontSize="11" Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                  </StackPanel>
                </ToggleButton>
              </Border>
              <Border Grid.Column="2" Background="#F4F4F5" CornerRadius="10" Padding="4">
                <ToggleButton x:Name="SegOutbound" Style="{StaticResource SegOutboundBtn}" HorizontalAlignment="Stretch">
                  <StackPanel>
                    <TextBlock Text="Исходящие" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="трафик с ПК" FontSize="11" Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                  </StackPanel>
                </ToggleButton>
              </Border>
            </Grid>
            <TextBlock x:Name="TxtDirectionHint" Text="Входящие: фильтрует подключения извне к вашему компьютеру" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,16" TextWrapping="Wrap"/>

            <TextBlock Text="Название" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="InpName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

            <TextBlock Text="Действие" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="#F4F4F5" CornerRadius="10" Padding="4">
                <ToggleButton x:Name="SegAllow" Style="{StaticResource SegAllowBtn}" Content="Разрешить" IsChecked="True" HorizontalAlignment="Stretch"/>
              </Border>
              <Border Grid.Column="2" Background="#F4F4F5" CornerRadius="10" Padding="4">
                <ToggleButton x:Name="SegBlock" Style="{StaticResource SegBlockBtn}" Content="Заблокировать" HorizontalAlignment="Stretch"/>
              </Border>
            </Grid>

            <TextBlock Text="Протокол" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbProtocol" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16">
              <ComboBoxItem Content="TCP" IsSelected="True"/>
              <ComboBoxItem Content="UDP"/>
              <ComboBoxItem Content="ICMPv4"/>
              <ComboBoxItem Content="ICMPv6"/>
              <ComboBoxItem Content="GRE"/>
              <ComboBoxItem Content="IGMP"/>
              <ComboBoxItem Content="SCTP"/>
              <ComboBoxItem Content="ESP"/>
              <ComboBoxItem Content="AH"/>
              <ComboBoxItem Content="TCP + UDP"/>
              <ComboBoxItem Content="Любой"/>
            </ComboBox>

            <TextBlock Text="Порты" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="InpPorts" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
            <TextBlock Text="Пример: 80, 443, 1000-1010. Пусто = все порты" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,16"/>

            <TextBlock Text="IP-адреса (удалённые)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="InpRemoteIp" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
            <TextBlock Text="Пример: 192.168.1.1, 10.0.0.0/24. Пусто = любые. Входящие: источник, исходящие: назначение" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,16"/>

            <TextBlock Text="IP-адреса (локальные)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="InpLocalIp" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
            <TextBlock Text="Локальный IP интерфейса. Обычно оставляют пустым" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,16"/>

            <TextBlock Text="Профили сети" Style="{StaticResource FieldLabel}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
              <CheckBox x:Name="ChkDomain" Content="Домен" IsChecked="True" Margin="0,0,16,0" ToolTip="Корпоративная сеть"/>
              <CheckBox x:Name="ChkPrivate" Content="Частная" IsChecked="True" Margin="0,0,16,0" ToolTip="Домашняя или офисная сеть"/>
              <CheckBox x:Name="ChkPublic" Content="Публичная" IsChecked="True" ToolTip="Публичные Wi‑Fi и интернет"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button x:Name="BtnModalCancel" Style="{StaticResource GhostButton}" Content="Отмена" Margin="0,0,8,0"/>
              <Button x:Name="BtnModalCreate" Style="{StaticResource PrimaryButton}" Content="Создать"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>